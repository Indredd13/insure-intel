# ─── Database ─────────────────────────────────────────────────────────────────
# Local development: SQLite file (default)
DATABASE_URL="file:./dev.db"

# Production: Turso (libSQL) — set both to use Turso instead of local SQLite
# Get these from: https://turso.tech/app → select your database → "Edit Tables"
# TURSO_DATABASE_URL="libsql://your-db-name-your-username.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"
